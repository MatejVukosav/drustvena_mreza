<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="15dp"
    android:layout_weight="2"
    android:orientation="vertical"
    android:background="@color/background_like_and_comment">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="25dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <Button
            android:id="@+id/like_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:drawableLeft="@drawable/ic_thumb_up"
            android:drawablePadding="6dp"
            android:drawableStart="@drawable/ic_thumb_up"
            android:textStyle="bold"
            android:text="Like" />

        <TextView
            android:id="@+id/core_home_num_of_likes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:layout_marginLeft="10dp"
            tools:text="num_of_likes" />


        <android.widget.Space
            android:layout_width="2dp"
            android:layout_height="wrap_content" />


        <Button
            android:id="@+id/comments_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="30dp"
            android:background="@android:color/transparent"
            android:drawableLeft="@drawable/messenger_bubble_large_white"
            android:drawablePadding="6dp"
            android:drawableStart="@drawable/messenger_bubble_large_white"
            android:textStyle="bold"
            android:text="Comment" />


        <TextView
            android:id="@+id/core_home_comments"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:textSize="12sp"
            tools:text="num_of_comments" />

    </LinearLayout>

</LinearLayout>
